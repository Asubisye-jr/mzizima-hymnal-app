<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <!-- Song Title -->
    <TextView
        android:id="@+id/songTitleTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="25sp"
        android:textStyle="bold"
        android:textAlignment="viewStart"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/audioIcon"
        tools:text="Amazing Grace" />

    <!-- Audio Icon -->
    <ImageView
        android:id="@+id/audioIcon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="8dp"
        android:contentDescription="Play audio"
        android:padding="6dp"
        android:src="@drawable/ic_audio"
        app:layout_constraintTop_toTopOf="@id/songTitleTextView"
        app:layout_constraintBottom_toBottomOf="@id/songTitleTextView"
        app:layout_constraintEnd_toStartOf="@id/sheetIcon" />

    <!-- Sheet Icon -->
    <ImageView
        android:id="@+id/sheetIcon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="8dp"
        android:contentDescription="View sheet music"
        android:padding="6dp"
        android:src="@drawable/img"
        app:layout_constraintTop_toTopOf="@id/songTitleTextView"
        app:layout_constraintBottom_toBottomOf="@id/songTitleTextView"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ScrollView for Lyrics -->
    <ScrollView
        android:id="@+id/lyricsScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/songTitleTextView"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/lyricsTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:textAlignment="center"
            android:textSize="20sp"
            tools:text="Amazing grace, how sweet the sound..." />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>