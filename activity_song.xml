<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:padding="8dp">

    <!-- Title -->
    <TextView
        android:id="@+id/songTitleTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textStyle="bold"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/audioIcon"
        tools:text="Amazing Grace" />

    <!-- Audio Icon -->
    <ImageView
        android:id="@+id/audioIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_audio"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="@id/songTitleTextView"
        app:layout_constraintBottom_toBottomOf="@id/songTitleTextView"
        app:layout_constraintEnd_toStartOf="@id/sheetIcon" />

    <!-- Sheet Icon -->
    <ImageView
        android:id="@+id/sheetIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/img"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="@id/songTitleTextView"
        app:layout_constraintBottom_toBottomOf="@id/songTitleTextView"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- SeekBar -->
    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/songTitleTextView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Controls -->
    <LinearLayout
        android:id="@+id/controlLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/seekBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnRewind"
            android:text="-10s"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnPlay"
            android:text="Play"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnPause"
            android:text="Pause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnForward"
            android:text="+10s"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>

    <!-- Lyrics -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/controlLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/lyricsTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:padding="12dp"
            android:textAlignment="center"/>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>